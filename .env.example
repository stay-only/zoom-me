# Salin menjadi .env (atau set sebagai environment variable di platform deploy)

# Port server (frontend + API + WebSocket dilayani dari port yang sama ini)
PORT=3000

# Opsional: daftar STUN/TURN server sendiri dalam format JSON (RTCIceServer[]).
# Tanpa ini, aplikasi memakai STUN Google + TURN publik gratis (openrelay) yang
# TIDAK dijamin untuk production. Untuk keandalan video lintas jaringan,
# jalankan TURN sendiri (mis. coturn) lalu isi seperti contoh:
# ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.domainanda.com:3478","username":"user","credential":"rahasia"}]
